{
  "acceptedRoots": ["tpm", "yubikey"],
  "allowedIds": [
    "openai-api-key",
    "anthropic-api-key",
    "github-token-readonly"
  ],
  "requiredRootsById": {
    "github-token-readonly": ["yubikey"]
  },
  "presenceMethod": "fingerprint",
  "requirePresenceForIds": [
    "github-token-readonly"
  ],
  "secondFactorMethod": "http",
  "secondFactorHttpUrl": "https://2fa.example.com",
  "secondFactorTimeoutSeconds": 90,
  "secondFactorCommandBin": "/usr/local/bin/hwvault-second-factor-approve",
  "secondFactorCommandArgs": ["--non-interactive"],
  "requireSecondFactorForIds": [
    "github-token-readonly"
  ],
  "defaultTtlSeconds": 120,
  "nonHardwareMaxTtlSeconds": 30
}
